{
  "name": "phpinspect",
  "version": "0.1.0",
  "description": "Offline PHP OOP code analyzer — detects code smells, generates UML diagrams, suggests refactoring",
  "main": "dist/index.js",
  "bin": {
    "phpinspect": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/cli.js"
  },
  "keywords": [
    "php",
    "oop",
    "uml",
    "code-smell",
    "static-analysis",
    "refactoring",
    "laravel",
    "solid",
    "design-patterns",
    "cyclomatic-complexity",
    "class-diagram",
    "mermaid"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/wakondadigital/phpinspect"
  },
  "author": "Wakonda Digital <contact@wakondadigital.com>",
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "README.md",
    "LICENSE"
  ],
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/node": "^22.0.0"
  },
  "dependencies": {
    "php-parser": "^3.2.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
